# 공공데이터포털 API Key (Decoding Key) [필수]
# 1. https://www.data.go.kr/data/15057511/openapi.do 에서 회원가입
# 2. "국토교통부_아파트매매 실거래 상세 자료" API 활용 신청
# 3. 마이페이지 → 오픈API → Decoding 키 복사
API_KEY=your_decoding_key_here

# Kakao Map API Key [선택]
# 지도 기능을 사용하려면 https://developers.kakao.com 에서 앱 생성 후
# JavaScript 키를 입력하세요. 없으면 지도 기능만 비활성화됩니다.
# KAKAO_KEY=your_kakao_javascript_key_here
